# Example secrets file for the Dialogue Branch Web Service.
#
# Copy this file to secrets.env, fill in your values, and reference it in
# your docker-compose.yml:
#
#   env_file:
#     - secrets.env
#
# Never commit secrets.env to version control.

# -----------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------
MARIADB_PASSWORD=

# -----------------------------------------------------------------------
# Keycloak admin (required when running the full docker-compose stack)
# -----------------------------------------------------------------------
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=

# -----------------------------------------------------------------------
# External Variable Service (required when EXTERNAL_VARIABLE_SERVICE_ENABLED=true)
# -----------------------------------------------------------------------
EXTERNAL_VARIABLE_SERVICE_URL=
EXTERNAL_VARIABLE_SERVICE_API_KEY=
