# Example environment file for the Dialogue Branch Web Client.
#
# Copy this file to .env (for `npm run dev` / `npm run build`) and fill in
# your values, or pass the equivalent `VITE_*` build args to `docker build`
# (see apps/web/Dockerfile).
#
# Vite only exposes env vars prefixed with VITE_ to client code, and bakes
# them into the static JS bundle at build time.
#
# This client talks only to the BFF (apps/bff), same-origin, never to the Dialogue Branch Web
# Service or Keycloak directly — see src/auth.js. There is nothing to configure here for local
# development: vite.config.js's dev-server proxy sends /api, /oauth2, /login, /logout, /whoami,
# and /actuator to a local BFF on http://localhost:8082 by default (override with VITE_BFF_TARGET,
# a plain shell env var, not a VITE_* one baked into the bundle).

# -----------------------------------------------------------------------
# Dialogue Branch API (relative — proxied through the BFF, see above)
# -----------------------------------------------------------------------
VITE_DLB_API_BASE_URL=/api/v1

# -----------------------------------------------------------------------
# Logging (0 = off, higher = more verbose)
# -----------------------------------------------------------------------
VITE_DLB_LOG_LEVEL=1
