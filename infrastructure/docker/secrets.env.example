# Example secrets file for the Dialogue Branch docker-compose stack.
#
# Copy this file to secrets.env, fill in your values, and keep it in the
# same directory as docker-compose.yml. Never commit secrets.env to version
# control.
#
# Generate strong random secrets with:
#   openssl rand -base64 64

# -----------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------
MARIADB_ROOT_PASSWORD=change-me-root-password
DLB_MARIADB_PASSWORD=change-me-db-password

# -----------------------------------------------------------------------
# Keycloak admin (required)
# -----------------------------------------------------------------------
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password
KC_DB_PASSWORD=change-me-kc-db-password

# -----------------------------------------------------------------------
# Keycloak client secret (required — must match the value in the realm)
# -----------------------------------------------------------------------
DLB_AUTH_KEYCLOAK_CLIENT_SECRET=change-me-keycloak-client-secret

# -----------------------------------------------------------------------
# JWT signing secrets for the API (required when DLB_AUTH_SERVICE=native)
# -----------------------------------------------------------------------
DLB_AUTH_JWT_ACCESS_TOKEN_SECRET=n47zoYup4MtUqBpGyQlXIzdAp9oDr8nuttJcfV1XUeG8R3LMyPcAYvTRFfuLrKuqeYRSY/h+ln8ve93jV24VNA==
DLB_AUTH_JWT_REFRESH_TOKEN_SECRET=Fy01u/aRN3TmjDJB/nBQI+M5R7ZGlIpL0ZpX4M8VwflP+JKoJFb3FIQKwvaQCpDzW8dV9SgQXnhAZue3N15hAg==
