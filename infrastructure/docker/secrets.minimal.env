# Secrets for the minimal Dialogue Branch stack (API + MariaDB, native auth).
#
# Copy this file to secrets.minimal.env, fill in your values, and keep it
# alongside the compose file. Never commit secrets.minimal.env to version control.
#
# Generate strong random secrets with:
#   openssl rand -base64 64

# -----------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------
# Both variables must be set to the same value — the API connects as root.
MARIADB_ROOT_PASSWORD=change-me-db-password
DLB_MARIADB_PASSWORD=change-me-db-password

# -----------------------------------------------------------------------
# JWT signing secrets for the API (required when DLB_AUTH_SERVICE=native)
# -----------------------------------------------------------------------
DLB_AUTH_JWT_ACCESS_TOKEN_SECRET=n47zoYup4MtUqBpGyQlXIzdAp9oDr8nuttJcfV1XUeG8R3LMyPcAYvTRFfuLrKuqeYRSY/h+ln8ve93jV24VNA==
